{
  "name": "@proctorio/hulk",
  "version": "2.1.0",
  "description": "Lightweight minification library for HTML, CSS, SVG, JavaScript, and JSON",
  "keywords": [
    "minify",
    "minifier",
    "html",
    "css",
    "svg",
    "javascript",
    "json",
    "compression",
    "optimize",
    "optimizer",
    "proctorio",
    "zero-dependencies",
    "lightweight",
    "regex",
    "html-minifier",
    "css-minifier",
    "svg-minifier",
    "js-minifier",
    "json-minifier"
  ],
  "main": "./lib/index.js",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proctorio/hulk.js.git"
  },
  "bugs": {
    "url": "https://github.com/proctorio/hulk.js/issues"
  },
  "homepage": "https://github.com/proctorio/hulk.js#readme",
  "scripts": {
    "build": "node -e \"require('fs').cpSync('src', 'lib', {recursive: true})\"",
    "test": "vitest run --coverage",
    "lint": "eslint --fix src/ test/",
    "lint:check": "eslint src/ test/",
    "prepublishOnly": "npm run build && npm test"
  },
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "author": "Proctorio",
  "license": "Apache-2.0",
  "devDependencies": {
    "@proctorio/eslint-config": "4.0.2",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "10.0.0",
    "vitest": "3.2.4"
  }
}